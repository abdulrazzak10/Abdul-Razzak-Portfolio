---
const services = [
  {
    title: "AI Agents",
    description: "I design and deploy AI agents that can reason, remember context, and take action — from answering customer questions to executing multi-step tasks autonomously. Built with LangChain, OpenAI, and custom tool integrations.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>` 
  },
  {
    title: "Automation Workflows",
    description: "I connect your tools — CRMs, databases, email, Slack, and spreadsheets — into smart, event-driven pipelines that run 24/7 without manual input. Built with Make.com, n8n, Python, and custom APIs.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h5"/><path d="M17 12h5"/><path d="m3 7 4 4"/><path d="m17 13 4 4"/><path d="M12 2v5"/><path d="M12 17v5"/><path d="m17 7-4 4"/><path d="m7 17 4-4"/></svg>` 
  },
  {
    title: "API Integrations",
    description: "I build secure, well-documented REST APIs and integrate third-party platforms so your systems communicate reliably. No more copy-pasting between tools or broken data syncs.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="8" y="8" rx="2"/><path d="M12 2v6"/><path d="M12 16v6"/><path d="M2 12h6"/><path d="M16 12h6"/></svg>` 
  },
  {
    title: "SaaS Tools",
    description: "I develop focused, fast SaaS products with clean UI and solid backends — from idea to deployed product. Built with Next.js, Node.js, Supabase, and Stripe-ready architecture.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>` 
  }
];
---
<section id="services" class="text-[var(--white)] py-12 md:py-24 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">What I Build</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-12">Services</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(svc => (
        <div class="p-8 rounded-2xl bg-[#1414149c] border border-[var(--white-icon-tr)] hover:-translate-y-1 hover:shadow-xl hover:border-[var(--white-icon)] transition-all duration-300">
          <div class="w-14 h-14 bg-black/50 rounded-xl mb-6 flex items-center justify-center text-[var(--sec)] border border-[var(--white-icon-tr)]" set:html={svc.icon} />
          <h4 class="text-2xl font-bold mb-3">{svc.title}</h4>
          <p class="text-[var(--white-icon)] leading-relaxed">{svc.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
