---
interface Project {
  title: string;
  image: string;
  problem: string;
  solution: string;
  techStack: string[];
  link: string;
  preview: string;
  status: string;
}

const projects: Project[] = [
  {
    title: "Digital Footprint Analyzer",
    image: "/images/project-dfa.png",
    problem: "Security teams waste hours manually gathering OSINT data across platforms, ending up with incomplete and disconnected results.",
    solution: "Built a fully automated OSINT analysis tool that uses AI to collect, correlate, and surface actionable threat intelligence from across the web — all in one unified dashboard. Reduced manual research time by over 70%.",
    techStack: ["Python", "FastAPI", "React", "LangChain", "OpenAI"],
    link: "https://github.com/abdulrazzak10/cyber-footprint-scan",
    preview: "#",
    status: "Completed",
  },
  {
    title: "AI Customer Support Agent",
    image: "/images/project-acsa.png",
    problem: "A high volume of repetitive support tickets was overloading the team, causing slow response times and frustrated customers.",
    solution: "Deployed a RAG-powered AI support agent trained on the company's internal knowledge base. It now resolves 80% of L1 queries instantly, 24/7 — cutting average response time from hours to seconds.",
    techStack: ["Next.js", "Node.js", "Pinecone", "OpenAI API"],
    link: "https://github.com/abdulrazzak10/",
    preview: "#",
    status: "Deployed",
  },
  {
    title: "Automated B2B Lead Generator",
    image: "/images/project-ablg.png",
    problem: "Sales reps were spending 3 to 4 hours daily manually researching, filtering, and scoring leads before making a single outreach.",
    solution: "Built an end-to-end lead generation pipeline that scrapes prospects, enriches their profiles, scores them using an LLM, and pushes qualified leads directly into the CRM — fully on autopilot.",
    techStack: ["Python", "Playwright", "Make.com", "Airtable API"],
    link: "https://github.com/abdulrazzak10/",
    preview: "#",
    status: "Active",
  },
  {
    title: "AI Meeting Summarizer",
    image: "/images/project-ams.png",
    problem: "Teams lose hours every week manually writing meeting notes, action items, and follow-up emails after every call.",
    solution: "Built an automated pipeline that records calls, transcribes audio using Whisper, summarizes key decisions with GPT-4, and sends structured action items to each participant via email within minutes.",
    techStack: ["Python", "Whisper API", "OpenAI", "FastAPI", "SMTP"],
    link: "https://github.com/abdulrazzak10/",
    preview: "#",
    status: "In Progress",
  },
  {
    title: "Custom RAG Business System",
    image: "/images/project-crbs.png",
    problem: "Businesses with large internal knowledge bases struggle to give employees or customers fast, accurate answers without hiring extra support staff.",
    solution: "Developed a fully custom RAG chatbot system that ingests company documents, indexes them into a vector database, and answers natural language queries with source-cited responses in real time.",
    techStack: ["Next.js", "LangChain", "Pinecone", "OpenAI API", "Supabase"],
    link: "https://github.com/abdulrazzak10/",
    preview: "#",
    status: "Deployed",
  }
];
---

<section
  id="projects"
  class="py-12 md:py-24 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-12">Projects</h3>

    <div class="space-y-8">
      {
        projects.map((project) => (
          <div class="group rounded-2xl overflow-hidden bg-[#1414149c] border border-[var(--white-icon-tr)] hover:border-[var(--white-icon)] transition-all duration-300">
            <div class="flex flex-col md:flex-row">
              <div class="w-full md:w-2/5 min-h-[250px] overflow-hidden flex-shrink-0 relative">
                <div class="absolute inset-0 bg-[#00000060] group-hover:bg-[#00000010] transition-colors duration-500 z-10 pointer-events-none"></div>
                <img 
                  src={project.image} 
                  alt={project.title} 
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-in-out absolute inset-0"
                  loading="lazy"
                />
              </div>
              <div class="w-full md:w-3/5 p-6 md:p-8 flex flex-col justify-between">
                <div>
                  <div class="flex justify-between items-start mb-4 gap-4">
                    <h4 class="text-2xl font-bold">{project.title}</h4>
                    <span class="px-3 py-1 text-xs rounded-full border border-[var(--white-icon-tr)] bg-black/40 text-[var(--white-icon)] whitespace-nowrap">
                      {project.status}
                    </span>
                  </div>
                  
                  <div class="space-y-4 mb-6">
                    <div>
                      <h5 class="text-[var(--sec)] text-sm font-semibold mb-1 uppercase tracking-wider">Problem</h5>
                      <p class="text-[var(--white-icon)] text-sm md:text-base leading-relaxed">{project.problem}</p>
                    </div>
                    <div>
                      <h5 class="text-[var(--sec)] text-sm font-semibold mb-1 uppercase tracking-wider">Solution</h5>
                      <p class="text-[var(--white)] text-sm md:text-base leading-relaxed">{project.solution}</p>
                    </div>
                  </div>
                </div>

                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-t border-[var(--white-icon-tr)] pt-6 mt-2">
                  <div class="flex flex-wrap gap-2">
                    {project.techStack.map(tech => (
                      <span class="text-xs bg-black/50 text-[var(--white-icon)] px-2.5 py-1 rounded-md border border-[var(--white-icon-tr)]">
                        {tech}
                      </span>
                    ))}
                  </div>
                  <div class="flex gap-2">
                    <a
                      target="_blank"
                      href={project.link}
                      aria-label="GitHub"
                      class="flex justify-center items-center text-[var(--white-icon)] hover:text-[var(--sec)] transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-2.5 rounded-xl bg-black/40 hover:bg-black/60"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6"><path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" /></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
    
    <a
      target="_blank"
      href="https://github.com/abdulrazzak10?tab=repositories"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-12 text-[var(--white-icon)] hover:text-[var(--sec)] transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:border-[var(--sec)] hover:scale-[1.02]"
    >
      <span class="md:text-lg text-md">More projects on GitHub</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6"><path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"></path></svg>
    </a>
  </div>
</section>
