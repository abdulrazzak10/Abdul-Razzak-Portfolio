---
const skillGroups = [
  {
    title: "AI & Automation",
    skills: ["AI Agents", "LLM Integration", "Workflow Automation", "LangChain", "Vector DBs"]
  },
  {
    title: "Frontend",
    skills: ["React", "Next.js", "Astro", "Tailwind CSS", "Framer Motion"]
  },
  {
    title: "Backend",
    skills: ["Node.js", "Python", "FastAPI", "REST APIs", "PostgreSQL"]
  },
  {
    title: "Tools & DevOps",
    skills: ["Git", "Docker", "AWS", "Vercel", "CI/CD"]
  }
];
---
<section id="skills" class="text-[var(--white)] py-12 md:py-24 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Technical Arsenal</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-12">Skills</h3>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      {skillGroups.map((group) => (
        <div class="p-6 rounded-2xl bg-[#1414149c] border border-[var(--white-icon-tr)] shadow-lg hover:border-[var(--white-icon)] transition-colors duration-300 group">
          <h4 class="text-xl font-semibold mb-6 flex items-center gap-2 group-hover:text-[var(--sec)] transition-colors">
            {group.title}
          </h4>
          <ul class="flex flex-col gap-3">
            {group.skills.map(skill => (
              <li class="text-[var(--white-icon)] text-sm md:text-base flex items-center gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--sec)] shadow-[0_0_8px_var(--sec)]"></div>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
